---
import "../styles/global.css";

const {
  title = "RTSC Drill Catalog",
  description = "Coach-friendly drill catalog and curated session plans."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={`${Astro.base || ""}/`}>RTSC Drill Catalog</a>
        <nav class="site-nav" aria-label="Primary">
          <a href={`${Astro.base || ""}/drills`}>Drills</a>
          <a href={`${Astro.base || ""}/session-plans`}>Session Plans</a>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
    </div>
  </body>
</html>
