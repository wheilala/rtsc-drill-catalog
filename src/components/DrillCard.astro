---
import { withBase } from "../lib/paths.js";

const { drill } = Astro.props;
const groupSizeLabel =
  drill.groupSize?.min || drill.groupSize?.max
    ? `${drill.groupSize?.min ?? "?"}-${drill.groupSize?.max ?? "?"} players`
    : "Group size flexible";

const shortMeta = drill.pitchSize ? `${groupSizeLabel} · ${drill.pitchSize}` : groupSizeLabel;
---

<article
  class="drill-card"
  data-drill-card
  data-topics={JSON.stringify(drill.topics || [])}
  data-min={drill.groupSize?.min ?? ""}
  data-max={drill.groupSize?.max ?? ""}
  data-has-video={drill.videos?.length ? "true" : "false"}
>
  <a class="drill-card-link" href={withBase(`/drills/${drill.slug}`)}>
    <div class="drill-card-media">
      {drill.diagram?.localPath ? (
        <img class="drill-card-image" src={withBase(drill.diagram.localPath)} alt={drill.diagram.alt || ""} />
      ) : (
        <div class="drill-card-image placeholder">No diagram yet</div>
      )}
    </div>
    <div class="drill-card-body">
      <div class="drill-card-topics">
        {(drill.topics || []).map((topic) => (
          <span class="pill">{topic}</span>
        ))}
      </div>
      <h3>{drill.title}</h3>
      <p class="drill-card-summary">{drill.summary || "No summary added yet."}</p>
      <div class="drill-card-meta">
        <span>{shortMeta}</span>
      </div>
    </div>
  </a>
</article>
